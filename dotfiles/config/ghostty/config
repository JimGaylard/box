# Ghostty configuration
# Deployed by Ansible from dotfiles/config/ghostty/ -> ~/.config/ghostty/
# Reload in-app with cmd+shift+, ; list all options with: ghostty +show-config --default --docs

# Font: match the Nerd Font installed via the macos playbook so icons/powerline glyphs render
font-family = MesloLGS Nerd Font
font-size = 14

# Theme (run `ghostty +list-themes` to browse alternatives)
theme = catppuccin-mocha

# Window
background-opacity = 0.98
window-padding-x = 8
window-padding-y = 6
macos-titlebar-style = tabs

# Cursor
cursor-style = block
shell-integration-features = no-cursor

# Scrollback
scrollback-limit = 10000

# Don't prompt when closing a surface with a running process
confirm-close-surface = false
